# ═══════════════════════════════════════════════════════════
#  BETORACLE PRO — Variables d'environnement Supabase
#  Copier ce fichier en .env et remplir les valeurs
#  ⚠️  Ne jamais committer .env sur GitHub
# ═══════════════════════════════════════════════════════════

# ── SUPABASE ──
SUPABASE_URL=https://TON_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=ta_clé_anon_publique
SUPABASE_SERVICE_ROLE_KEY=ta_clé_service_role_secrète

# ── API SPORTS (cotes & stats matchs) ──
# Créer un compte sur https://dashboard.api-football.com/
# Plan gratuit : 100 requêtes/jour (suffisant pour commencer)
API_SPORTS_KEY=ta_clé_api_sports

# ── TELEGRAM BOT ──
# 1. Crée un bot via @BotFather sur Telegram
# 2. Obtenir le token
# 3. Créer un canal et ajouter le bot comme admin
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHANNEL_ID=@betoracle_pro  # ou -1001234567890 (ID numérique)

# ── PAIEMENTS MOBILE MONEY (CinetPay) ──
# Doc : https://api.cinetpay.com/
# Supporte : Orange Money CI, MTN CI, Moov CI, Wave, Carte bancaire
CINETPAY_KEY=ta_clé_cinetpay
CINETPAY_SITEID=ton_site_id_cinetpay

# ── APP ──
APP_URL=https://betoracle.pro  # URL publique de l'app
ENV=production  # development | production

# ── LLM ORACLE (optionnel — améliore les prédictions) ──
# Anthropic (Claude) ou OpenAI pour enrichir les analyses
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
