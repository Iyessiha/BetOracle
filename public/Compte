      <!-- ═══ INFOS PERSONNELLES ═══ -->
      <div class="sec-head"><i class="ti ti-user" style="color:var(--green)"></i> Informations personnelles</div>
      <div class="card">
        <div class="card-body">
          <div class="info-row">
            <div class="ir-icon" style="background:rgba(34,197,94,.1);color:var(--green)"><i class="ti ti-user"></i></div>
            <div style="flex:1">
              <div class="ir-label">Nom complet</div>
              <div class="ir-val" id="ir-name">—</div>
            </div>
            <button class="btn-edit" onclick="openEditModal()" style="font-size:11px;padding:5px 10px"><i class="ti ti-pencil"></i></button>
          </div>
          <div class="info-row">
            <div class="ir-icon" style="background:rgba(45,212,191,.1);color:var(--teal)"><i class="ti ti-mail"></i></div>
            <div style="flex:1">
              <div class="ir-label">Email</div>
              <div class="ir-val" id="ir-email">—</div>
            </div>
            <span class="htag htag-ok" id="ir-verified-badge" style="font-size:10px;display:none">✓</span>
          </div>
          <div class="info-row">
            <div class="ir-icon" style="background:rgba(167,139,250,.1);color:var(--purple)"><i class="ti ti-phone"></i></div>
            <div style="flex:1">
              <div class="ir-label">Téléphone</div>
              <div class="ir-val" id="ir-phone" class="muted">Non renseigné</div>
            </div>
            <button class="btn-edit" onclick="openEditModal()" style="font-size:11px;padding:5px 10px"><i class="ti ti-pencil"></i></button>
          </div>
          <div class="info-row">
            <div class="ir-icon" style="background:rgba(255,255,255,.04);color:var(--lo)"><i class="ti ti-hash"></i></div>
            <div style="flex:1">
              <div class="ir-label">Identifiant unique</div>
              <div class="ir-val" id="ir-uid" style="font-family:monospace;font-size:12px;color:var(--lo);cursor:pointer" onclick="copyUid()">—</div>
            </div>
          </div>
          <div class="info-row">
            <div class="ir-icon" style="background:rgba(245,200,66,.1);color:var(--gold)"><i class="ti ti-gift"></i></div>
            <div style="flex:1">
              <div class="ir-label">Code parrainage</div>
              <div class="ir-val" id="ir-refcode" style="color:var(--gold)">—</div>
