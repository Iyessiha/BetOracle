        </div>
      </div>

      <!-- ═══ STATISTIQUES ═══ -->
      <div class="sec-head" style="margin-top:6px"><i class="ti ti-chart-bar" style="color:var(--gold)"></i> Activité</div>
      <div class="stats-row">
        <div class="stat-mini"><div class="sv" id="st-analyses">0</div><div class="sl">Analyses</div></div>
        <div class="stat-mini"><div class="sv" id="st-streak" style="color:var(--gold)">0</div><div class="sl">Streak jours</div></div>
        <div class="stat-mini"><div class="sv" id="st-refs" style="color:var(--teal)">0</div><div class="sl">Filleuls</div></div>
        <div class="stat-mini"><div class="sv" id="st-logins" style="color:var(--purple)">0</div><div class="sl">Connexions</div></div>
        <div class="stat-mini"><div class="sv" id="st-days" style="color:var(--green)">0</div><div class="sl">Jours restants</div></div>
      </div>

      <!-- ═══ ABONNEMENT ═══ -->
      <div class="sec-head" style="margin-top:6px"><i class="ti ti-crown" style="color:var(--gold)"></i> Abonnement</div>
      <div class="sub-card" id="sub-card" class="inactive">
        <div class="sub-plan-name" id="sub-plan-name">Free</div>
        <div class="sub-detail" id="sub-detail">Plan gratuit — accès limité</div>
        <div class="sub-expires exp" id="sub-expires">Aucun abonnement actif</div>
        <a href="/checkout" class="btn-upgrade"><i class="ti ti-bolt"></i> Passer Premium dès 750 FCFA</a>
      </div>

    </div>
