<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Mon compte — Betoracl Pro</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
<style>
:root{
  --green:#22c55e;--green-d:#16a34a;--gold:#F5C842;--teal:#2dd4bf;--red:#ef4444;--purple:#a78bfa;
  --bg:#080e08;--s1:#0f1510;--s2:#141e14;--b1:#1c2a1c;--b2:#243424;
  --hi:#e4ede4;--mid:#8aab8a;--lo:#4a6a4a;
  --ff:'Barlow',sans-serif;--fd:'Bebas Neue',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
html{-webkit-text-size-adjust:100%}
body{background:var(--bg);color:var(--hi);font-family:var(--ff);font-size:15px;line-height:1.6;min-height:100dvh}
a{text-decoration:none;color:inherit}
button{font-family:var(--ff)}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fadein{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
.fadein{animation:fadein .4s ease}

/* ── LAYOUT ── */
.app{display:flex;min-height:100dvh}
.sidebar{
  width:220px;flex-shrink:0;background:var(--s1);border-right:1px solid var(--b1);
  display:flex;flex-direction:column;
  position:fixed;top:0;left:0;height:100dvh;z-index:50;
  padding:0 0 20px;overflow-y:auto;
}
.main-wrap{flex:1;margin-left:220px;display:flex;flex-direction:column;min-height:100dvh}
.topbar{
  position:sticky;top:0;z-index:40;
  background:rgba(8,14,8,.92);backdrop-filter:blur(16px);
  border-bottom:1px solid var(--b1);
  height:60px;display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;
}
.content{padding:28px;max-width:800px}

/* ── SIDEBAR ── */
.sb-brand{display:flex;align-items:center;gap:10px;padding:20px 18px 12px;border-bottom:1px solid var(--b1);margin-bottom:12px}
.sb-orb{font-size:22px}
.sb-wordmark{font-family:var(--fd);font-size:17px;letter-spacing:.08em;color:var(--hi)}
.sb-wordmark em{color:var(--green);font-style:normal}
.sb-tag{font-size:9px;color:var(--lo);font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-top:1px}
.sb-user{display:flex;align-items:center;gap:10px;padding:10px 16px 12px;border-bottom:1px solid var(--b1);margin-bottom:10px}
.sb-av{width:34px;height:34px;border-radius:9px;background:rgba(34,197,94,.12);border:1.5px solid rgba(34,197,94,.25);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:16px;flex-shrink:0;color:var(--green)}
.sb-user-name{font-weight:700;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:120px}
.sb-user-plan{font-size:11px;font-weight:600;margin-top:1px}
.sb-nav{padding:0 10px;flex:1}
.sb-section{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--lo);padding:8px 8px 4px;margin-top:6px}
.sb-link{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:9px;font-size:13px;font-weight:600;color:var(--mid);transition:all .15s;margin-bottom:1px}
.sb-link:hover{background:var(--s2);color:var(--hi)}
.sb-link.on{background:rgba(34,197,94,.1);color:var(--green)}
.sb-link i{font-size:16px;flex-shrink:0}
.sb-badge{font-size:10px;font-weight:700;padding:1px 7px;border-radius:10px;margin-left:auto;background:rgba(34,197,94,.12);color:var(--green)}
.sb-badge.g{background:rgba(245,200,66,.12);color:var(--gold)}
.sb-div{height:1px;background:var(--b1);margin:8px 8px}
.sb-foot{padding:12px 10px 0;border-top:1px solid var(--b1);margin-top:auto;display:flex;flex-direction:column;gap:6px}
.sb-upgrade{display:flex;align-items:center;justify-content:center;gap:7px;padding:10px;border-radius:9px;background:var(--green);color:#000;font-size:13px;font-weight:800;text-align:center}
.sb-logout-btn{display:flex;align-items:center;justify-content:center;gap:7px;padding:9px;border-radius:9px;background:transparent;border:1px solid var(--b2);color:var(--lo);font-size:12px;font-weight:700;cursor:pointer;transition:all .15s}
.sb-logout-btn:hover{border-color:var(--red);color:var(--red)}

/* ── TOPBAR ── */
.topbar-title{font-family:var(--fd);font-size:18px;letter-spacing:.04em;color:var(--hi)}
.topbar-right{display:flex;align-items:center;gap:10px}
.plan-chip{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:700;padding:5px 12px;border-radius:20px;border:1px solid;color:var(--gold);border-color:rgba(245,200,66,.3);background:rgba(245,200,66,.08)}

/* ── MOBILE NAV ── */
.m-topbar{display:none;position:fixed;top:0;left:0;right:0;z-index:60;height:52px;background:rgba(8,14,8,.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--b1);align-items:center;justify-content:space-between;padding:0 16px}
.m-brand{display:flex;align-items:center;gap:8px;font-family:var(--fd);font-size:16px;letter-spacing:.06em;color:var(--hi);text-decoration:none}
.m-brand em{color:var(--green);font-style:normal}
.m-orb{font-size:18px}
.m-right{display:flex;align-items:center;gap:8px}
.m-plan-chip{font-size:11px;font-weight:700;padding:4px 10px;border-radius:14px;border:1px solid;color:var(--gold);border-color:rgba(245,200,66,.3);background:rgba(245,200,66,.08)}
.m-menu-btn{background:none;border:none;color:var(--mid);font-size:20px;cursor:pointer;padding:4px}
.m-bnav{display:none;position:fixed;bottom:0;left:0;right:0;z-index:60;background:rgba(8,14,8,.96);backdrop-filter:blur(12px);border-top:1px solid var(--b1);height:62px;align-items:center;justify-content:space-around;padding:0 4px;padding-bottom:env(safe-area-inset-bottom,0)}
.bn-item{display:flex;flex-direction:column;align-items:center;gap:3px;font-size:10px;font-weight:700;color:var(--lo);padding:6px 10px;border-radius:8px;text-decoration:none;cursor:pointer;background:none;border:none;letter-spacing:.02em;transition:color .15s;flex:1;max-width:72px}
.bn-item i{font-size:19px;line-height:1}
.bn-item.on{color:var(--green)}
.bn-item.bn-cta{color:var(--gold)}

/* ── DRAWER ── */
.drawer-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:70;backdrop-filter:blur(2px)}
.drawer-bg.open{display:block}
.drawer{display:none;position:fixed;top:0;left:0;bottom:0;width:260px;z-index:80;background:var(--s1);border-right:1px solid var(--b2);padding:0;overflow-y:auto;transform:translateX(-100%);transition:transform .25s ease}
.drawer.open{display:block;transform:none}
.dr-head{display:flex;align-items:center;justify-content:space-between;padding:16px 18px;border-bottom:1px solid var(--b1)}
.dr-user{display:flex;align-items:center;gap:10px;padding:14px 18px;border-bottom:1px solid var(--b1)}
.dr-av{width:38px;height:38px;border-radius:10px;background:rgba(34,197,94,.12);border:1.5px solid rgba(34,197,94,.25);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:18px;flex-shrink:0;color:var(--green)}
.dr-name{font-weight:700;font-size:14px}
.dr-plan{font-size:11px;font-weight:600;margin-top:2px}
.dr-nav{padding:10px 12px}
.dr-section{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--lo);padding:6px 6px 3px;margin-top:4px}
.dr-link{display:flex;align-items:center;gap:9px;padding:9px 8px;border-radius:8px;font-size:13px;font-weight:600;color:var(--mid);margin-bottom:1px}
.dr-link:hover{background:var(--s2);color:var(--hi)}
.dr-link.on{color:var(--green);background:rgba(34,197,94,.08)}
.dr-div{height:1px;background:var(--b1);margin:6px 6px}
.dr-foot{padding:12px;border-top:1px solid var(--b1);margin-top:8px;display:flex;flex-direction:column;gap:6px}
.dr-btn-up{display:flex;align-items:center;justify-content:center;gap:7px;padding:10px;border-radius:9px;background:var(--green);color:#000;font-size:13px;font-weight:800}
.dr-btn-out{display:flex;align-items:center;justify-content:center;gap:7px;padding:9px;border-radius:9px;background:transparent;border:1px solid var(--b2);color:var(--lo);font-size:12px;font-weight:700;cursor:pointer;transition:all .15s}
.dr-btn-out:hover{border-color:var(--red);color:var(--red)}

/* ── SECTION ── */
.sec-head{display:flex;align-items:center;gap:8px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--lo);margin-bottom:14px;margin-top:4px}
.card{background:var(--s1);border:1px solid var(--b1);border-radius:16px;overflow:hidden;margin-bottom:16px}
.card-hd{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--b1)}
.card-title{font-weight:700;font-size:14px;display:flex;align-items:center;gap:8px}
.card-body{padding:16px 20px}

/* ── PROFIL HERO ── */
.profil-hero{
  background:var(--s1);border:1px solid var(--b2);border-radius:18px;
  padding:28px 24px;margin-bottom:18px;position:relative;overflow:hidden;
}
.profil-hero::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--green),var(--gold))}
.hero-row{display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.hero-av{
  width:80px;height:80px;border-radius:20px;flex-shrink:0;
  background:rgba(34,197,94,.1);border:2px solid rgba(34,197,94,.25);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--fd);font-size:38px;color:var(--green);
  cursor:pointer;position:relative;overflow:hidden;
}
.hero-av:hover::after{content:'📷';position:absolute;inset:0;background:rgba(0,0,0,.55);display:flex;align-items:center;justify-content:center;font-size:22px;border-radius:18px}
.hero-av img{width:100%;height:100%;object-fit:cover;border-radius:18px}
.hero-info{flex:1;min-width:200px}
.hero-name{font-family:var(--fd);font-size:26px;letter-spacing:.04em;color:var(--hi);line-height:1.1;margin-bottom:3px}
.hero-email{font-size:13px;color:var(--lo);margin-bottom:12px}
.hero-tags{display:flex;flex-wrap:wrap;gap:6px}
.htag{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;border:1px solid;white-space:nowrap}
.htag-plan{background:rgba(245,200,66,.08);color:var(--gold);border-color:rgba(245,200,66,.25)}
.htag-exp{background:rgba(34,197,94,.08);color:var(--green);border-color:rgba(34,197,94,.2)}
.htag-ok{background:rgba(45,212,191,.08);color:var(--teal);border-color:rgba(45,212,191,.2)}
.htag-free{background:rgba(255,255,255,.03);color:var(--lo);border-color:var(--b2)}
.hero-meta{display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0}
.hero-id{font-size:11px;color:var(--lo);background:rgba(0,0,0,.3);border:1px solid var(--b1);border-radius:8px;padding:5px 10px;font-family:monospace;cursor:pointer;white-space:nowrap;max-width:200px;overflow:hidden;text-overflow:ellipsis}
.hero-since{font-size:11px;color:var(--lo)}
.btn-edit{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:700;padding:8px 16px;border-radius:9px;border:1px solid var(--b2);background:transparent;color:var(--mid);cursor:pointer;transition:all .15s;text-decoration:none}
.btn-edit:hover{border-color:var(--green);color:var(--hi)}

/* ── INFO ROWS ── */
.info-row{display:flex;align-items:center;padding:12px 0;border-bottom:1px solid var(--b1);font-size:14px;gap:10px}
.info-row:last-child{border-bottom:none}
.info-row .ir-icon{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.info-row .ir-label{color:var(--lo);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-bottom:1px}
.info-row .ir-val{font-weight:700;font-size:14px;color:var(--hi)}
.info-row .ir-val.muted{color:var(--lo);font-weight:500}

/* ── ABONNEMENT ── */
.sub-card{background:var(--s2);border-radius:12px;padding:18px;margin-bottom:12px;border:1px solid var(--b1);position:relative;overflow:hidden}
.sub-card.active::before{content:'';position:absolute;top:0;left:0;bottom:0;width:3px;background:var(--green)}
.sub-card.inactive::before{content:'';position:absolute;top:0;left:0;bottom:0;width:3px;background:var(--b2)}
.sub-plan-name{font-family:var(--fd);font-size:20px;letter-spacing:.04em;margin-bottom:4px}
.sub-detail{font-size:12px;color:var(--lo);margin-bottom:12px}
.sub-expires{font-size:12px;font-weight:700;color:var(--green);background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:8px;padding:4px 10px;display:inline-block}
.sub-expires.exp{color:var(--lo);background:rgba(255,255,255,.02);border-color:var(--b1)}
.btn-upgrade{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:11px 22px;border-radius:10px;background:var(--gold);color:#000;font-size:13px;font-weight:800;margin-top:14px;text-decoration:none;transition:background .15s}
.btn-upgrade:hover{background:#ffe066}

/* ── STAT MINI ── */
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:16px}
.stat-mini{background:var(--s2);border-radius:12px;padding:14px 12px;text-align:center;border:1px solid var(--b1)}
.stat-mini .sv{font-family:var(--fd);font-size:26px;letter-spacing:.04em;color:var(--green);line-height:1}
.stat-mini .sl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--lo);margin-top:3px}

/* ── MODAL ÉDITION ── */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;align-items:center;justify-content:center;padding:20px}
.modal-bg.open{display:flex}
.modal{background:var(--s1);border:1px solid var(--b2);border-radius:20px;width:100%;max-width:420px;overflow:hidden}
.modal-head{padding:20px 24px;border-bottom:1px solid var(--b1);display:flex;align-items:center;justify-content:space-between}
.modal-head h3{font-family:var(--fd);font-size:20px;letter-spacing:.04em}
.modal-close{background:none;border:none;color:var(--lo);cursor:pointer;font-size:20px;padding:4px}
.modal-body{padding:22px 24px;display:flex;flex-direction:column;gap:14px}
.modal-field label{display:block;font-size:11px;font-weight:700;color:var(--lo);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px}
.modal-field input{width:100%;background:var(--bg);border:1px solid var(--b2);border-radius:8px;padding:10px 14px;font-size:14px;color:var(--hi);font-family:var(--ff);outline:none}
.modal-field input:focus{border-color:var(--green)}
.modal-field input:disabled{opacity:.5;cursor:not-allowed}
.modal-save{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:13px;border-radius:10px;background:var(--green);color:#000;font-size:14px;font-weight:800;border:none;cursor:pointer;font-family:var(--ff);margin-top:4px;transition:background .15s}
.modal-save:hover{background:#4ade80}
.modal-save:disabled{opacity:.6;cursor:not-allowed}
.modal-msg{font-size:12px;text-align:center;min-height:18px}

@media(max-width:768px){
  .sidebar{display:none}
  .main-wrap{margin-left:0;padding-top:52px;padding-bottom:70px}
  .topbar{display:none}
  .m-topbar{display:flex}
  .m-bnav{display:flex}
  .content{padding:16px}
  .hero-meta{flex-direction:row;align-items:center}
  .stats-row{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>

