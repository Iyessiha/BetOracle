</div>

<!-- ════════ BOTTOM NAV MOBILE ════════ -->
<nav class="m-bnav">
  <a href="/dashboard" class="bn-item"><i class="ti ti-layout-dashboard"></i>Accueil</a>
  <a href="/analyse"   class="bn-item"><i class="ti ti-brain"></i>Oracle</a>
  <a href="/checkout"  class="bn-item bn-cta"><i class="ti ti-bolt"></i>Plans</a>
  <a href="/compte"    class="bn-item on"><i class="ti ti-user-circle"></i>Compte</a>
  <button class="bn-item" onclick="openDr()"><i class="ti ti-menu-2"></i>Menu</button>
</nav>

<!-- ════════ MODAL ÉDITION PROFIL ════════ -->
<div class="modal-bg" id="edit-modal" onclick="if(event.target===this)closeEditModal()">
  <div class="modal">
    <div class="modal-head">
      <h3>Modifier mon profil</h3>
      <button class="modal-close" onclick="closeEditModal()"><i class="ti ti-x"></i></button>
    </div>
    <div class="modal-body">
      <div class="modal-field">
        <label>Nom complet</label>
        <input type="text" id="edit-name" placeholder="Prénom Nom" maxlength="60">
      </div>
      <div class="modal-field">
        <label>Email</label>
        <input type="email" id="edit-email" placeholder="email@example.com" disabled>
      </div>
      <div class="modal-field">
        <label>Téléphone (optionnel)</label>
        <input type="tel" id="edit-phone" placeholder="+225 07 00 00 00 00" maxlength="20">
      </div>
      <div class="modal-msg" id="edit-msg"></div>
      <button class="modal-save" id="edit-save" onclick="saveProfile()">
        <i class="ti ti-check"></i> Enregistrer
      </button>
    </div>
  </div>
</div>

<script>
const S  = 'https://ovulcqsrzkwlnhnyllij.supabase.co'
const AK = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im92dWxjcXNyemt3bG5obnlsbGlqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEzNDc1NzgsImV4cCI6MjA5NjkyMzU3OH0.eJvZE2tgYB42CHYyosZGp8YiMZw4YJRJbdR3d_mmvLw'

const PL = {
  free:    ['🆓 Free',    '#4a6a4a'],
  starter: ['🌱 Starter', '#2dd4bf'],
  pro:     ['⚡ Pro',     '#F5C842'],
  elite:   ['👑 Elite',   '#a78bfa'],
}

let _uid = '', _refcode = ''
function $(id) { return document.getElementById(id) }
window.openDr  = () => { $('dbg').classList.add('open'); $('dr').classList.add('open'); document.body.style.overflow='hidden' }
window.closeDr = () => { $('dbg').classList.remove('open'); $('dr').classList.remove('open'); document.body.style.overflow='' }

// ── AUTH ──
async function tryRefresh() {
  const r = localStorage.getItem('sb_refresh_token'); if (!r) return null
  const res = await fetch(`${S}/auth/v1/token?grant_type=refresh_token`,{method:'POST',headers:{'Content-Type':'application/json','apikey':AK},body:JSON.stringify({refresh_token:r})}).catch(()=>null)
  if (!res?.ok) return null
  const d = await res.json()
  if (d.access_token) { localStorage.setItem('sb_access_token',d.access_token); localStorage.setItem('sb_refresh_token',d.refresh_token||r); sessionStorage.setItem('bp_token',d.access_token); return d.access_token }
  return null
}
async function getToken() {
  let t = localStorage.getItem('sb_access_token') || sessionStorage.getItem('bp_token'); if (!t) return null
  const ok = await fetch(`${S}/auth/v1/user`,{headers:{apikey:AK,Authorization:`Bearer ${t}`}}).then(r=>r.ok).catch(()=>false)
  return ok ? t : tryRefresh()
}

// ── FILL UI ──
function fillUI(name, plan) {
  const [label, color] = PL[plan] || PL.free
  const init = (name||'P')[0].toUpperCase()
  $('sb-av').textContent = init; $('sb-name').textContent = name||'Parieur'
  Object.assign($('sb-plan'), {textContent:label, style:`color:${color}`})
  Object.assign($('tb-plan'), {textContent:label, style:`color:${color};border-color:${color}40`})
  Object.assign($('m-plan'),  {textContent:label, style:`color:${color};border-color:${color}40;background:${color}12`})
  $('dr-av').textContent = init; $('dr-name').textContent = name||'Parieur'
  Object.assign($('dr-plan'), {textContent:label, style:`color:${color}`})
  $('hero-av').textContent = init
  $('hero-name').textContent = name||'Parieur'
  Object.assign($('hero-plan'), {textContent:label, style:`background:${color}12;color:${color};border-color:${color}30`})
}

// ── INIT ──
(async () => {
  // Cache rapide
  const cn = sessionStorage.getItem('bp_prenom') || localStorage.getItem('sb_user_name')
  const cp = sessionStorage.getItem('bp_plan') || localStorage.getItem('bp_plan') || 'free'
  if (cn) fillUI(cn, cp)

  const token = await getToken()
  if (!token) { window.location.href = '/login'; return }

  const authRes = await fetch(`${S}/auth/v1/user`, {headers:{apikey:AK, Authorization:`Bearer ${token}`}})
  if (!authRes.ok) { window.location.href = '/login'; return }
  const authUser = await authRes.json()

  const profRes = await fetch(`${S}/rest/v1/profiles?id=eq.${authUser.id}&select=id,full_name,email,phone,plan,plan_expires_at,email_verified,ref_code,referral_count,login_count,streak_days,analyses_today,country,created_at`,
    {headers:{apikey:AK, Authorization:`Bearer ${token}`, 'Content-Type':'application/json'}})
  const profArr = await profRes.json()
  const p = (Array.isArray(profArr) ? profArr[0] : null) || {}

  _uid     = p.id || authUser.id
  _refcode = p.ref_code || ''
  const email = authUser.email || ''
  const now = new Date()
  const ePlan = (p.plan_expires_at && new Date(p.plan_expires_at) > now && ['starter','pro','elite'].includes(p.plan)) ? p.plan : 'free'
  const fullName = p.full_name || email.split('@')[0] || 'Parieur'
  const [planLabel, planColor] = PL[ePlan] || PL.free

  // ── SIDEBAR / TOPBAR
  fillUI(fullName.split(' ')[0], ePlan)
  sessionStorage.setItem('bp_plan', ePlan)
  sessionStorage.setItem('bp_prenom', fullName.split(' ')[0])

  // ── HERO
  $('hero-name').textContent  = fullName
  $('hero-av').textContent    = fullName[0].toUpperCase()
  $('hero-email').textContent = email
  $('hero-id').textContent    = `ID: ${_uid.slice(0,8)}…`
  $('hero-id').title          = _uid
  Object.assign($('hero-plan'), {textContent:planLabel, style:`background:${planColor}12;color:${planColor};border-color:${planColor}30`})

  if (p.plan_expires_at && new Date(p.plan_expires_at) > now && ePlan !== 'free') {
    const exp = new Date(p.plan_expires_at).toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'})
    $('hero-exp').textContent = `Exp. ${exp}`; $('hero-exp').style.display = 'inline-flex'
  }
  if (p.email_verified) { $('hero-verified').style.display = 'inline-flex' }
  if (p.created_at) $('hero-since').textContent = `Membre depuis ${new Date(p.created_at).toLocaleDateString('fr-FR',{month:'long',year:'numeric'})}`

  // ── INFOS
  $('ir-name').textContent   = fullName
  $('ir-email').textContent  = email
  $('ir-phone').textContent  = p.phone || 'Non renseigné'
  if (!p.phone) $('ir-phone').style.color = 'var(--lo)'
  $('ir-uid').textContent    = _uid
  $('ir-refcode').textContent = _refcode || '—'
  if (p.email_verified) $('ir-verified-badge').style.display = 'inline-flex'
  if (p.created_at) $('ir-since').textContent = new Date(p.created_at).toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'})

  // ── STATS
  $('st-analyses').textContent = p.analyses_today || 0
  $('st-streak').textContent   = p.streak_days || 0
  $('st-refs').textContent     = p.referral_count || 0
  $('st-logins').textContent   = p.login_count || 0
  if (p.plan_expires_at && new Date(p.plan_expires_at) > now && ePlan !== 'free') {
    $('st-days').textContent = Math.max(0, Math.ceil((new Date(p.plan_expires_at)-now)/86400000))
  } else { $('st-days').textContent = '0' }

  // ── ABONNEMENT
  const sc = $('sub-card')
  if (ePlan !== 'free' && p.plan_expires_at && new Date(p.plan_expires_at) > now) {
    sc.classList.remove('inactive'); sc.classList.add('active')
    $('sub-plan-name').textContent = planLabel
    $('sub-plan-name').style.color = planColor
    const period = p.period || ''
    $('sub-detail').textContent = `Abonnement ${ePlan} actif`
    const expDate = new Date(p.plan_expires_at).toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'})
    const expEl = $('sub-expires')
    expEl.textContent = `✅ Actif jusqu'au ${expDate}`
    expEl.classList.remove('exp')
    // Cacher le bouton upgrade si déjà premium
    const btn = sc.querySelector('.btn-upgrade')
    if (btn) btn.style.display = 'none'
  }

  // ── SESSION
  sessionStorage.setItem('bp_uid',      _uid)
  sessionStorage.setItem('bp_email',    email)
  sessionStorage.setItem('bp_full_name',fullName)
  sessionStorage.setItem('bp_phone',    p.phone || '')

  // ── PRÉ-REMPLIR MODAL
  $('edit-name').value  = fullName
  $('edit-email').value = email
  $('edit-phone').value = p.phone || ''
})()

// ── COPIER UID ──
window.copyUid = function() {
  if (!_uid) return
  navigator.clipboard.writeText(_uid).then(() => {
    const el = $('ir-uid'); const orig = el.textContent
    el.textContent = '✓ ID copié !'
    setTimeout(() => { el.textContent = orig }, 1800)
  }).catch(() => {})
}

// ── COPIER REF ──
window.copyRef = function() {
  const url = `https://betoracl.com/signup?ref=${_refcode}`
  navigator.clipboard.writeText(url).then(() => {
    const el = $('ir-refcode'); const orig = el.textContent
    el.textContent = '✓ Lien copié !'
    setTimeout(() => { el.textContent = orig }, 1800)
  }).catch(() => {})
}

// ── MODAL ──
window.openEditModal = function() {
  $('edit-name').value  = sessionStorage.getItem('bp_full_name') || ''
  $('edit-email').value = sessionStorage.getItem('bp_email') || ''
  $('edit-phone').value = sessionStorage.getItem('bp_phone') || ''
  $('edit-msg').textContent = ''
  $('edit-modal').classList.add('open')
}
window.closeEditModal = function() { $('edit-modal').classList.remove('open') }

window.saveProfile = async function() {
  const btn = $('edit-save'), msg = $('edit-msg')
  const name = $('edit-name').value.trim()
  const phone = $('edit-phone').value.trim()
  if (!name) { msg.style.color='var(--red)'; msg.textContent='Le nom est requis.'; return }
  btn.disabled = true
  btn.innerHTML = '<i class="ti ti-loader-2" style="animation:spin 1s linear infinite"></i> Enregistrement…'
  msg.textContent = ''
  try {
    const uid   = sessionStorage.getItem('bp_uid') || ''
    const token = localStorage.getItem('sb_access_token') || sessionStorage.getItem('bp_token') || ''
    if (!uid || !token) throw new Error('Non authentifié')
    const res = await fetch(`${S}/rest/v1/profiles?id=eq.${uid}`,{method:'PATCH',headers:{'Content-Type':'application/json','apikey':AK,'Authorization':`Bearer ${token}`,'Prefer':'return=minimal'},body:JSON.stringify({full_name:name, phone:phone||null, updated_at:new Date().toISOString()})})
    if (!res.ok) throw new Error(`HTTP ${res.status}`)
    // Mise à jour UI
    sessionStorage.setItem('bp_full_name', name)
    sessionStorage.setItem('bp_phone', phone)
    const init = name[0].toUpperCase()
    ;['hero-av','sb-av','dr-av'].forEach(id => $(id) && ($(id).textContent = init))
    $('hero-name').textContent = name; $('ir-name').textContent = name
    $('sb-name').textContent   = name.split(' ')[0]; $('dr-name').textContent = name.split(' ')[0]
    $('ir-phone').textContent  = phone || 'Non renseigné'
    $('ir-phone').style.color  = phone ? 'var(--hi)' : 'var(--lo)'
    msg.style.color = 'var(--green)'; msg.textContent = '✓ Profil mis à jour !'
    setTimeout(() => closeEditModal(), 1200)
  } catch(e) {
    msg.style.color = 'var(--red)'; msg.textContent = 'Erreur : ' + e.message
  } finally {
    btn.disabled = false; btn.innerHTML = '<i class="ti ti-check"></i> Enregistrer'
  }
}

// ── LOGOUT ──
window.doLogout = function() {
  ;['sb_access_token','sb_refresh_token','sb_user_id','bp_plan','bp_prenom','bp_uid','bp_email','bp_full_name','bp_phone'].forEach(k => localStorage.removeItem(k))
  sessionStorage.clear()
  window.location.href = '/login'
}
</script>
</body>
</html>
