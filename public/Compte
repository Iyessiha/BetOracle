    </div>
  </aside>

  <!-- MAIN -->
  <div class="main-wrap">
    <header class="topbar">
      <div class="topbar-title">Mon compte</div>
      <div class="topbar-right">
        <div class="plan-chip" id="tb-plan">Free</div>
      </div>
    </header>

    <div class="content fadein">

      <!-- ═══ HERO PROFIL ═══ -->
      <div class="profil-hero">
        <div class="hero-row">
          <div class="hero-av" id="hero-av" onclick="openEditModal()">?</div>
          <div class="hero-info">
            <div class="hero-name" id="hero-name">Chargement…</div>
            <div class="hero-email" id="hero-email">—</div>
            <div class="hero-tags">
              <span class="htag htag-plan" id="hero-plan">Free</span>
              <span class="htag htag-exp"  id="hero-exp"  style="display:none"></span>
              <span class="htag htag-ok"   id="hero-verified" style="display:none">✓ Email vérifié</span>
            </div>
          </div>
          <div class="hero-meta">
            <div class="hero-id" id="hero-id" title="" onclick="copyUid()">ID: …</div>
            <div class="hero-since" id="hero-since">Membre depuis …</div>
            <button class="btn-edit" onclick="openEditModal()"><i class="ti ti-pencil"></i> Modifier</button>
