            <button onclick="copyRef()" style="font-size:11px;padding:5px 10px;border:1px solid var(--b2);border-radius:8px;background:none;color:var(--lo);cursor:pointer;font-family:var(--ff)"><i class="ti ti-copy"></i></button>
          </div>
          <div class="info-row" style="border-bottom:none">
            <div class="ir-icon" style="background:rgba(255,255,255,.03);color:var(--lo)"><i class="ti ti-calendar"></i></div>
            <div style="flex:1">
              <div class="ir-label">Membre depuis</div>
              <div class="ir-val" id="ir-since" style="color:var(--lo)">—</div>
            </div>
